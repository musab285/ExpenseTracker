# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-change-this-in-production
ALLOWED_HOSTS=yourdomain.railway.app,www.yourdomain.com

# Database (PostgreSQL)
DATABASE=your_database_name
user=postgres
PASSWORD=your_postgres_password
HOST=your-postgres-host
PORT=5432

# CORS - Frontend URLs
CORS_ALLOWED_ORIGINS=https://yourdomain.railway.app,https://www.yourdomain.com

# CSRF trusted browser origins
CSRF_TRUSTED_ORIGINS=https://yourdomain.railway.app,https://www.yourdomain.com

# JWT Settings (Optional - defaults are configured)
# ACCESS_TOKEN_LIFETIME=30  # minutes
# REFRESH_TOKEN_LIFETIME=7  # days
